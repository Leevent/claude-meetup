---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
---

<BaseLayout
  title="提示詞產生器｜Claude 台中小聚"
  description="用六元素框架（R-T-C-F-Q-E）組合出專業 Claude Prompt。即時預覽、一鍵複製，適合初學者快速掌握提示詞技巧。"
  canonical="https://claudetc.leevent.xyz/prompt-builder/"
  active="prompt-builder"
  keywords="Claude 提示詞, Prompt 產生器, AI 提示詞框架, RTCFQE, 台中小聚"
>

<Breadcrumb items={[{ name: '首頁', href: '/' }, { name: '提示詞產生器' }]} />

<div class="max-w-6xl mx-auto px-4 sm:px-6 pb-16">

  <!-- Hero -->
  <div class="pt-4 pb-8 text-center">
    <div class="badge badge-primary badge-outline mb-4 px-4 py-3 text-sm font-bold">R-T-C-F-Q-E 六元素框架</div>
    <h1 class="text-3xl sm:text-4xl font-black mb-3">提示詞產生器</h1>
    <p class="text-base-content/60 max-w-xl mx-auto text-sm leading-relaxed">
      填入六個元素，即時組合出專業 Prompt。<br/>
      基於 Anthropic、Google、OpenAI 三家官方文件整理。
    </p>
  </div>

  <!-- Quick templates -->
  <div class="flex flex-wrap gap-2 justify-center mb-8">
    <span class="text-xs text-base-content/40 self-center">快速範例：</span>
    <button class="btn btn-xs btn-outline" onclick="loadTpl('social')">社群貼文</button>
    <button class="btn btn-xs btn-outline" onclick="loadTpl('meeting')">會議紀錄</button>
    <button class="btn btn-xs btn-outline" onclick="loadTpl('brand')">品牌文案</button>
    <button class="btn btn-xs btn-outline" onclick="loadTpl('report')">分析報告</button>
    <button class="btn btn-xs btn-ghost text-error ml-2" onclick="clearAll()">清除</button>
  </div>

  <div class="grid lg:grid-cols-2 gap-6">

    <!-- Left: Inputs -->
    <div class="space-y-4">

      <!-- Progress -->
      <div class="flex items-center gap-3">
        <progress id="prog-bar" class="progress progress-primary flex-1 h-2" value="0" max="6"></progress>
        <span id="prog-text" class="text-xs text-base-content/50 whitespace-nowrap">0 / 6 已填寫</span>
      </div>

      <div class="form-control">
        <label class="label pb-1">
          <span class="label-text font-bold flex items-center gap-2">
            <span class="badge badge-primary badge-sm font-black">R</span>
            角色 <span class="text-base-content/40 font-normal">Role</span>
          </span>
          <span class="label-text-alt text-base-content/40">告訴 Claude 用什麼身份回答</span>
        </label>
        <textarea id="f-role" class="textarea textarea-bordered textarea-sm w-full resize-none" rows="2"
          placeholder="例：你是一位有 10 年經驗的社群行錠專家" oninput="updateAll()"></textarea>
      </div>

      <div class="form-control">
        <label class="label pb-1">
          <span class="label-text font-bold flex items-center gap-2">
            <span class="badge badge-primary badge-sm font-black">T</span>
            任務 <span class="text-base-content/40 font-normal">Task</span>
          </span>
          <span class="label-text-alt text-base-content/40">你需要 Claude 做什麼？越具體越好</span>
        </label>
        <textarea id="f-task" class="textarea textarea-bordered textarea-sm w-full resize-none" rows="3"
          placeholder="例：幫我撰寫一篇 Threads 貼文，推廣我們的新課程" oninput="updateAll()"></textarea>
      </div>

      <div class="form-control">
        <label class="label pb-1">
          <span class="label-text font-bold flex items-center gap-2">
            <span class="badge badge-secondary text-secondary-content badge-sm font-black">C</span>
            背景 <span class="text-base-content/40 font-normal">Context</span>
          </span>
          <span class="label-text-alt text-base-content/40">提供相關背景、限制條件</span>
        </label>
        <textarea id="f-context" class="textarea textarea-bordered textarea-sm w-full resize-none" rows="3"
          placeholder="例：課程主題是 Claude AI 應用，目標受眾是 25-40 歲上班族，品牌調性輕鬆專業" oninput="updateAll()"></textarea>
      </div>

      <div class="form-control">
        <label class="label pb-1">
          <span class="label-text font-bold flex items-center gap-2">
            <span class="badge badge-accent text-accent-content badge-sm font-black">F</span>
            格式 <span class="text-base-content/40 font-normal">Format</span>
          </span>
          <span class="label-text-alt text-base-content/40">你想要什麼樣的輸出格式</span>
        </label>
        <textarea id="f-format" class="textarea textarea-bordered textarea-sm w-full resize-none" rows="2"
          placeholder="例：300 字以內、包含一個 CTA、用條列式重點、附上 3 個 hashtag" oninput="updateAll()"></textarea>
      </div>

      <div class="form-control">
        <label class="label pb-1">
          <span class="label-text font-bold flex items-center gap-2">
            <span class="badge badge-warning text-warning-content badge-sm font-black">Q</span>
            品質標準 <span class="text-base-content/40 font-normal">Quality</span>
          </span>
          <span class="label-text-alt text-base-content/40">什麼樣的結果才算好？</span>
        </label>
        <textarea id="f-quality" class="textarea textarea-bordered textarea-sm w-full resize-none" rows="2"
          placeholder="例：語氣親切但專業、避免過度销售感、需要包含具體數據或案例" oninput="updateAll()"></textarea>
      </div>

      <div class="form-control">
        <label class="label pb-1">
          <span class="label-text font-bold flex items-center gap-2">
            <span class="badge badge-success badge-sm font-black text-success-content">E</span>
            範例 <span class="text-base-content/40 font-normal">Examples</span>
          </span>
          <span class="label-text-alt text-xs text-primary font-semibold">最有效的提示技巧 ★</span>
        </label>
        <p class="text-xs text-base-content/50 mb-2 leading-relaxed">
          貼上一段你期望的輸出樣式，或類似問題的好答案。Anthropic、Google、OpenAI
          三家官方文件一致認為，<strong>提供範例是讓 AI 快速對齊你期望的最有效方法</strong>。
        </p>
        <textarea id="f-examples" class="textarea textarea-bordered textarea-sm w-full resize-none" rows="3"
          placeholder="例：我剛開始學 Claude，有點不知道從哪裡下手&#10;→ 建議先從日常工作中找一件重複性高的小事，用 Claude 幫你做一次，感受差異之後，再慢慢擴展使用場景。" oninput="updateAll()"></textarea>
      </div>

    </div>

    <!-- Right: Preview + Tips -->
    <div class="lg:sticky lg:top-24 lg:self-start space-y-4">

      <div class="card bg-base-100 border border-base-300 shadow-sm">
        <div class="card-body p-5">
          <div class="flex items-center justify-between mb-3">
            <h2 class="card-title text-base">產生的 Prompt</h2>
            <button id="copy-btn" class="btn btn-primary btn-sm" onclick="copyPrompt()" disabled>
              複製 Prompt
            </button>
          </div>
          <div class="bg-base-200 rounded-xl p-4 min-h-48">
            <pre id="preview" class="whitespace-pre-wrap text-sm font-sans leading-relaxed text-base-content/50 italic">開始填寫左邊的欄位，Prompt 會即時出現在這裡...</pre>
          </div>
          <div id="hint" class="hidden text-xs text-warning mt-2">
            ⚠ <span id="hint-text"></span>
          </div>
        </div>
      </div>

      <div class="card bg-primary/5 border border-primary/10">
        <div class="card-body p-5">
          <h3 class="font-bold text-sm mb-3 flex items-center gap-2">
            💡 Prompt 小技巧
            <span class="badge badge-primary badge-xs">官方來源</span>
          </h3>
          <ul class="space-y-3 text-xs text-base-content/70">
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5 shrink-0">▸</span>
              <span>
                <strong>告訴 Claude 要「做什麼」</strong>，比說「不要做什麼」更有效 — Anthropic 官方文件：正向指令（Tell Claude what to do）比反面限制更精準
                <span class="badge badge-xs ml-1 opacity-60">Anthropic</span>
              </span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5 shrink-0">▸</span>
              <span>
                <strong>範例 (E) 是最高 CP 値的技巧</strong> — 給 Claude 1-2 個好範例，比寫 5 行指令更有效，三家官方文件一致建議
                <span class="badge badge-xs ml-1 opacity-60">三家共同</span>
              </span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5 shrink-0">▸</span>
              <span>
                先要求列出 2-3 種方案，選定再執行，試錯時間減少一半
                <span class="badge badge-xs ml-1 opacity-60">Google</span>
              </span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5 shrink-0">▸</span>
              <span>
                避免用問句代替指令 — 「請幫我...」比「你可以幫我...嗎？」效果好
                <span class="badge badge-xs ml-1 opacity-60">Anthropic</span>
              </span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5 shrink-0">▸</span>
              <span>
                單一任務完成就開新對話 — Context 越長 AI 越容易漂移
                <span class="badge badge-xs ml-1 opacity-60">三家共同</span>
              </span>
            </li>
          </ul>
        </div>
      </div>

    </div>
  </div>
</div>

<script is:inline>
var TEMPLATES={
  social:{
    role:'你是一位擅長台灣市場的社群行錠專家，風格輕鬆但專業',
    task:'撰寫一篇 Threads 貼文，分享 AI 工具使用心得',
    context:'目標受眾是 25-40 歲科技業上班族，對 AI 有興趣但還沒深入使用',
    format:'300 字以內、分段清晰、結尾附一個互動問題和 3 個 hashtag',
    quality:'語氣像朋友分享經驗、避免術語堆砗、需包含一個具體使用場景',
    examples:'我用 Claude 寫完了過去要花 2 小時的週報，現在 20 分鐘搞定。

秘訣不是叫它「寫週報」，而是給它模板+背景+這週的重點事項。

你現在最想用 AI 省掘哪一個工作環節？'
  },
  meeting:{role:'你是一位專業的專案管理助理',task:'將以下會議逐字稿整理成結構化的會議紀錄',context:'這是行錠部門的週會，討論了下季度的推廣計畫',format:'包含：決議事項（表格）、行動項目（負責人+截止日）、未決議題、下次會議提醒',quality:'確保每個行動項目都有明確的負責人和截止日期，模糊的討論用「待確認」標註',examples:''},
  brand:{role:'你是一位品牌策略顧問，專精 B2B 科技產品行錠',task:'為我們的 AI 教育課程撰寫官網的價値主張區塊',context:'課程品牌定位是「讓非技術人員也能掌握 AI 生產力」，競品主打技術深度',format:'一句主標題（15 字內）+三段特色描述（各 50 字）+一個 CTA 按鈕文字',quality:'強調「實用>技術」，避免誧大承諾，語氣自信但不傲慢',examples:''},
  report:{role:'你是一位資深數據分析師，擅長商業洞察報告',task:'分析以下數據，產出一份執行摘要報告',context:'這份報告給非技術背景的管理層看，重點是行動建議而非數據技術細節',format:'執行摘要（3點）+關鍵發現（表格）+行動建議（優先度排序）',quality:'每項建議需附上具體行動步驟，避免模糊的「加強溝通」類建議',examples:''}
};
function getField(id){var el=document.getElementById(id);return el?el.value.trim():"";}
function buildPrompt(){
  var parts=[],r=getField('f-role'),t=getField('f-task'),c=getField('f-context'),fo=getField('f-format'),q=getField('f-quality'),e=getField('f-examples');
  if(r)parts.push('## 角色
'+r);
  if(t)parts.push('## 任務
'+t);
  if(c)parts.push('## 背景資訊
'+c);
  if(fo)parts.push('## 輸出格式
'+fo);
  if(q)parts.push('## 品質要求
'+q);
  if(e)parts.push('## 參考範例
請參考以下範例的格式和風格來回答：

'+e);
  return parts.join('

');
}
function countFilled(){var ids=['f-role','f-task','f-context','f-format','f-quality','f-examples'],c=0;for(var i=0;i<ids.length;i++){if(getField(ids[i]))c++;}return c;}
function updateAll(){
  var p=buildPrompt(),filled=countFilled();
  var pre=document.getElementById('preview'),btn=document.getElementById('copy-btn');
  var pb=document.getElementById('prog-bar'),pt=document.getElementById('prog-text');
  var hint=document.getElementById('hint'),ht=document.getElementById('hint-text');
  if(p){pre.textContent=p;pre.classList.remove('italic','text-base-content/50');btn.disabled=false;}
  else{pre.textContent='開始填寫左邊的欄位，Prompt 會即時出現在這裡...';pre.classList.add('italic','text-base-content/50');btn.disabled=true;}
  pb.value=filled;pt.textContent=filled+' / 6 已填寫';
  if(filled>0&&filled<6){hint.classList.remove('hidden');ht.textContent='還有 '+(6-filled)+' 個欄位未填，填越完整效果越好';}
  else hint.classList.add('hidden');
}
function loadTpl(key){
  var tpl=TEMPLATES[key];if(!tpl)return;
  ['role','task','context','format','quality','examples'].forEach(function(k){document.getElementById('f-'+k).value=tpl[k]||'';});
  updateAll();
}
function clearAll(){['f-role','f-task','f-context','f-format','f-quality','f-examples'].forEach(function(id){document.getElementById(id).value='';});updateAll();}
function copyPrompt(){
  var p=buildPrompt();if(!p)return;
  var btn=document.getElementById('copy-btn');
  if(navigator.clipboard){navigator.clipboard.writeText(p).then(function(){btn.textContent='✓ 已複製！';btn.classList.add('btn-success');btn.classList.remove('btn-primary');setTimeout(function(){btn.textContent='複製 Prompt';btn.classList.remove('btn-success');btn.classList.add('btn-primary');},2000);});}
  else{var ta=document.createElement('textarea');ta.value=p;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);btn.textContent='✓ 已複製！';setTimeout(function(){btn.textContent='複製 Prompt';},2000);}
}
</script>

</BaseLayout>
