---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const organizationLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Claude 台中小聚",
  "url": "https://claudetc.leevent.xyz",
  "description": "台中第一個 Claude AI 使用者線下交流社群",
  "founder": {
    "@type": "Person",
    "name": "Lee Vent",
    "url": "https://leevent.xyz"
  },
  "location": {
    "@type": "Place",
    "name": "台中",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "台中市",
      "addressCountry": "TW"
    }
  }
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "首頁", "item": "https://claudetc.leevent.xyz/" },
    { "@type": "ListItem", "position": 2, "name": "社群" }
  ]
};

const originSteps = [
  {
    num: "01",
    title: "為什麼在台中？",
    desc: "台灣的 Claude 使用者正在快速成長，但一直缺少一個線下交流場域。台北有各種 AI 活動，台中卻幾乎是空白。我們決定改變這件事。"
  },
  {
    num: "02",
    title: "一個人的決定",
    desc: "2026 年初，Lee Vent 決定在台中開始第一場小聚。沒有大型贊助、沒有百人場地，就是找一個舒服的空間，把同城的 Claude 使用者聚在一起。"
  },
  {
    num: "03",
    title: "不是演講，是實戰",
    desc: "不是演講，是一場邊聊邊做的實戰交流。帶著筆電來，帶著問題來，現場就開始解題。這是我們的核心信念。"
  }
];

const journeyPhases = [
  {
    phase: "Phase 0",
    label: "種子期",
    emoji: "🌱",
    title: "路過訪客",
    desc: "在社群看到活動、朋友轉貼、或是做了段位測驗，開始好奇「台中居然有 Claude 聚會？」",
    action: "看到活動 / 測段位",
    hrClass: "bg-success",
    circleClass: "bg-success/20",
    badgeClass: "badge-success"
  },
  {
    phase: "Phase 1",
    label: "固圈期",
    emoji: "🎟️",
    title: "活動參加者",
    desc: "決定行動，買一張 $600 的票，帶著筆電走進會場。第一次見到同城的 Claude 使用者，發現原來不只自己在用。",
    action: "買票 $600 · 到場參加",
    hrClass: "bg-info",
    circleClass: "bg-info/20",
    badgeClass: "badge-info"
  },
  {
    phase: "Phase 2",
    label: "深化期",
    emoji: "🔄",
    title: "活躍成員",
    desc: "參加過一次就回不去了。開始期待下一場、加入群組討論、跟其他成員交換工作流。",
    action: "回頭客 · 早鳥通知 · 深度交流",
    hrClass: "bg-secondary",
    circleClass: "bg-secondary/20",
    badgeClass: "badge-secondary"
  },
  {
    phase: "Phase 3",
    label: "飛輪期",
    emoji: "🔑",
    title: "核心圈成員",
    desc: "社群自轉的飛輪啟動。你不只是參加者，你開始貢獻——分享自己的用法、帶新朋友來、甚至協辦活動。",
    action: "活動精華 · 資源包 · 成員目錄 · 共創",
    hrClass: "bg-primary",
    circleClass: "bg-primary/20",
    badgeClass: "badge-primary"
  }
];

const testimonials = [
  "第一次看到有人把 Claude 用到這種程度，完全打開了新世界的大門。",
  "帶了筆電來，現場就把自己的工作流改好了，效率直接翻倍。",
  "認識了好多台中在地的 AI 同好，這才是最有價值的部分。",
  "本來以為自己用得還不錯，結果發現差距超大，收穫滿滿。",
  "氣氛很好，沒有距離感，大家都很願意分享自己的經驗和踩坑紀錄。",
  "終於在台中有地方可以聊 AI 了，不用每次都跑台北。"
];

const values = [
  {
    emoji: "🏙️",
    title: "認識同城用戶",
    desc: "線上聊千句，不如線下見一面。在台中找到跟你一樣在用 Claude 的人，建立真實的在地連結。"
  },
  {
    emoji: "🖥️",
    title: "看真實工作流",
    desc: "不是 PPT 簡報，是打開螢幕給你看的真實操作。從 prompt 到產出，完整的工作流程不藏私。"
  },
  {
    emoji: "🎯",
    title: "帶問題來解",
    desc: "帶著你卡住的問題來，現場就有人幫你看、幫你拆、幫你想解法。不是理論，是即時解題。"
  },
  {
    emoji: "🌱",
    title: "社群種子",
    desc: "每一場小聚都是社群的種子。我們相信，台中的 AI 社群會從這裡開始，慢慢長大。"
  }
];
---

<BaseLayout
  title="社群｜Claude 台中小聚"
  description="認識 Claude 台中小聚社群。從一個想法到台中第一個 AI 使用者在地 Mastermind 社群的故事。成員旅程、參加者心得、社群數據。"
  canonical="https://claudetc.leevent.xyz/community/"
  active="community"
  jsonLd={[organizationLd, breadcrumbLd]}
>
  <!-- Breadcrumb -->
  <Breadcrumb items={[
    { name: "首頁", href: "/" },
    { name: "社群" }
  ]} />

  <!-- Hero -->
  <section class="py-24 text-center relative overflow-hidden px-6" role="banner">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute w-[600px] h-[400px] top-[30%] left-[35%] -translate-x-1/2 -translate-y-1/2 bg-success/12 rounded-full blur-3xl"></div>
      <div class="absolute w-[500px] h-[400px] bottom-[20%] right-[30%] translate-x-1/2 translate-y-1/2 bg-secondary/8 rounded-full blur-3xl"></div>
    </div>

    <div class="relative z-10 max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-black leading-tight mb-5 text-base-content">
        Claude 台中小聚的故事
      </h1>
      <p class="text-lg text-base-content/70 leading-relaxed">
        從一個想法，到台中第一個 AI 使用者在地 Mastermind 社群。
      </p>
    </div>
  </section>

  <!-- Origin Story -->
  <section class="py-20 border-t border-base-300" aria-labelledby="origin-heading">
    <div class="max-w-3xl mx-auto px-6">
      <SectionHeader overline="Origin Story" title="起源故事" id="origin-heading" />

      <div class="flex flex-col gap-6 fade-in">
        {originSteps.map((step) => (
          <div class="card bg-base-200 border border-base-300 p-6 relative overflow-hidden">
            <div class="absolute top-4 right-5 text-5xl font-black text-success/10 select-none" aria-hidden="true">
              {step.num}
            </div>
            <div class="relative z-10">
              <div class="badge badge-success badge-outline text-xs font-bold mb-3">{step.num}</div>
              <h3 class="text-lg font-bold mb-2">{step.title}</h3>
              <p class="text-sm text-base-content/70 leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Member Journey -->
  <section class="py-20 bg-base-200 border-t border-base-300" aria-labelledby="journey-heading">
    <div class="max-w-4xl mx-auto px-6">
      <SectionHeader overline="Member Journey" title="成員旅程" subtitle="從路過訪客到核心圈成員，每個人都有自己的節奏。" id="journey-heading" />

      <ul class="timeline timeline-vertical fade-in">
        {journeyPhases.map((phase, i) => (
          <li>
            {i > 0 && <hr class={phase.hrClass} />}
            <div class="timeline-start text-right pr-2">
              <div class="text-xs font-bold text-base-content/60 uppercase">{phase.phase}</div>
              <div class="text-sm font-bold">{phase.label}</div>
            </div>
            <div class="timeline-middle">
              <span class={`w-10 h-10 rounded-full ${phase.circleClass} flex items-center justify-center text-lg`}>
                {phase.emoji}
              </span>
            </div>
            <div class="timeline-end timeline-box bg-base-100 border-base-300">
              <h3 class="font-bold mb-1">{phase.title}</h3>
              <p class="text-sm text-base-content/70 leading-relaxed mb-3">{phase.desc}</p>
              <div class={`badge ${phase.badgeClass} badge-outline text-xs`}>{phase.action}</div>
            </div>
            {i < journeyPhases.length - 1 && <hr class={journeyPhases[i + 1].hrClass} />}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Community Stats -->
  <section class="py-20 border-t border-base-300" aria-labelledby="stats-heading">
    <div class="max-w-5xl mx-auto px-6">
      <SectionHeader overline="Community Data" title="社群數據" id="stats-heading" />

      <div class="stats stats-vertical md:stats-horizontal w-full bg-base-200 border border-base-300 shadow-lg fade-in">
        <div class="stat place-items-center py-8">
          <div class="stat-value text-primary text-4xl font-black">1</div>
          <div class="stat-title text-base-content/70">累計場次</div>
        </div>
        <div class="stat place-items-center py-8">
          <div class="stat-value text-primary text-4xl font-black">40</div>
          <div class="stat-title text-base-content/70">累計參與</div>
        </div>
        <div class="stat place-items-center py-8">
          <div class="stat-value text-primary text-4xl font-black">--</div>
          <div class="stat-title text-base-content/70">職業分布</div>
          <div class="stat-desc text-base-content/50 italic">活動後更新</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial Wall -->
  <section class="py-20 bg-base-200 border-t border-base-300" aria-labelledby="testimonial-heading">
    <div class="max-w-5xl mx-auto px-6">
      <SectionHeader overline="Voices" title="參加者怎麼說" subtitle="真實回饋，來自每一位到場的人。" id="testimonial-heading" />

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 fade-in">
        {testimonials.map((quote) => (
          <div class="card bg-base-100 border border-base-300 p-5">
            <div class="text-2xl mb-3 text-base-content/20" aria-hidden="true">💬</div>
            <p class="text-sm text-base-content/70 italic leading-relaxed mb-4">「{quote}」</p>
            <div class="mt-auto">
              <p class="text-xs font-bold text-base-content/60">匿名參加者</p>
              <p class="text-xs text-base-content/30 italic">活動後更新</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 border-t border-base-300" aria-labelledby="values-heading">
    <div class="max-w-5xl mx-auto px-6">
      <SectionHeader overline="Our Values" title="我們相信的事" id="values-heading" />

      <div class="grid md:grid-cols-2 gap-5 fade-in">
        {values.map((v) => (
          <div class="card bg-base-200 border border-base-300 p-6 hover:border-primary/50 transition-colors">
            <span class="text-3xl mb-3 block">{v.emoji}</span>
            <h3 class="font-bold text-lg mb-2">{v.title}</h3>
            <p class="text-sm text-base-content/70 leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 text-center relative" id="join" aria-labelledby="cta-heading">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute w-[500px] h-[300px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-success/12 rounded-full blur-3xl"></div>
    </div>
    <div class="max-w-5xl mx-auto px-6 relative z-10">
      <h2 id="cta-heading" class="text-3xl md:text-4xl font-black mb-4">來參加下一場</h2>
      <p class="text-lg text-base-content/70 mb-9 leading-relaxed">
        帶著筆電、帶著問題來，帶著解法和朋友走。
      </p>
      <a href="/events/"
         class="btn btn-primary btn-lg text-lg shadow-lg shadow-primary/30 hover:shadow-xl hover:shadow-primary/40 hover:-translate-y-0.5 transition-all">
        查看活動 →
      </a>
      <p class="mt-5 text-sm text-base-content/50">
        或聯繫 <a href="mailto:vent@leevent.co" class="text-primary hover:underline">vent@leevent.co</a>
      </p>
    </div>
  </section>
</BaseLayout>
