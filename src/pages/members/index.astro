    // ── Crypto Helpers ──
    function sha256(str) {
      var encoder = new TextEncoder();
      var data = encoder.encode(str);
      return crypto.subtle.digest('SHA-256', data).then(function(buf) {
        var arr = Array.from(new Uint8Array(buf));
        return arr.map(function(b) { return b.toString(16).padStart(2, '0'); }).join('');
      });
    }

    function hashEmail(email) {
      return sha256(HASH_SALT + email.toLowerCase().trim());
    }

    function hashEmails(emails) {
      return Promise.all(emails.map(function(e) { return hashEmail(e); }));
    }

    // ── Google Sign-In ──
    function initGoogleSignIn() {
      if (typeof google === 'undefined' || !google.accounts) {
        setTimeout(function() {
          if (typeof google === 'undefined' || !google.accounts) {
            showPasswordFallback();
          } else {
            initGoogleSignIn();
          }
        }, 2000);
        return;
      }
      google.accounts.id.initialize({
        client_id: CLIENT_ID,
        callback: handleCredentialResponse,
        auto_select: false,
        cancel_on_tap_outside: true
      });
      google.accounts.id.renderButton(
        document.getElementById('google-signin-btn'),
        {
          theme: 'outline',
          size: 'large',
          type: 'standard',
          shape: 'rectangular',
          text: 'signin_with',
          locale: 'zh-TW',
          width: 280
        }
      );
    }

    function handleCredentialResponse(response) {
      try {
        var parts = response.credential.split('.');
        var payload = JSON.parse(atob(parts[1].replace(/-/g, '+').replace(/_/g, '/')));

        // Verify token
        if (payload.aud !== CLIENT_ID) {
          showGateError('驗證失敗：Token audience 不符');
          return;
        }
        if (payload.exp * 1000 < Date.now()) {
          showGateError('驗證失敗：Token 已過期');
          return;
        }
        if (payload.iss !== 'https://accounts.google.com' && payload.iss !== 'accounts.google.com') {
          showGateError('驗證失敗：Token issuer 不符');
          return;
        }
        if (!payload.email_verified) {
          showGateError('請使用已驗證的 Google 帳號');
          return;
        }

        var email = payload.email;
        var user = {
          name: payload.name || email.split('@')[0],
          email: email,
          picture: payload.picture || '',
          loginAt: Date.now()
        };

        // Whitelist check
        if (WHITELIST_ENABLED) {
          hashEmail(email).then(function(hash) {
            if (ALLOWED_HASHES.indexOf(hash) === -1) {
              showGateError('抱歉，此帳號不在核心圈名單中。如需加入請聯繫主辦人。');
              return;
            }
            sessionStorage.setItem(STORAGE_KEY, JSON.stringify(user));
            showMain(user);
          });
        } else {
          sessionStorage.setItem(STORAGE_KEY, JSON.stringify(user));
          showMain(user);
        }
      } catch (e) {
        showGateError('登入處理失敗，請重試。');
        console.error('Auth error:', e);
      }
    }

    // ── UI Helpers ──
    function showGateError(msg) {
      var el = document.getElementById('gate-err');
      el.textContent = msg;
      el.style.display = 'block';
    }

    function showPasswordFallback() {
      var el = document.getElementById('password-fallback');
      if (el) el.style.display = 'block';
    }

    function checkAccess() {
      try {
        var raw = sessionStorage.getItem(STORAGE_KEY);
        if (!raw) return null;
        var user = JSON.parse(raw);
        // 4-hour timeout
        if (Date.now() - user.loginAt > 4 * 60 * 60 * 1000) {
          sessionStorage.removeItem(STORAGE_KEY);
          return null;
        }
        return user;
      } catch (e) {
        return null;
      }
    }

    function showMain(user) {
      document.getElementById('gate').style.display = 'none';
      document.getElementById('main').style.display = 'block';

      // Set user info in nav
      var avatar = document.getElementById('nav-avatar');
      if (user.picture) {
        avatar.src = user.picture;
        avatar.style.display = 'inline-block';
      } else {
        avatar.style.display = 'none';
      }

      var displayName = user.name || user.email.split('@')[0];
      document.getElementById('nav-name').textContent = displayName;
      document.getElementById('welcome-name').textContent = displayName;
    }

    function logout() {
      sessionStorage.removeItem(STORAGE_KEY);
      document.getElementById('main').style.display = 'none';
      document.getElementById('gate').style.display = 'flex';
      document.getElementById('gate-err').style.display = 'none';
      // Reset nav
      document.getElementById('nav-avatar').src = '';
      document.getElementById('nav-name').textContent = '';
      // Revoke Google session if available
      if (typeof google !== 'undefined' && google.accounts && google.accounts.id) {
        google.accounts.id.disableAutoSelect();
      }
    }

    // ── Password Fallback ──
    var _passcodeAttempts = 0;
    var _passcodeLocked = false;

    (function() {
      var btn = document.getElementById('passcode-btn');
      var input = document.getElementById('passcode-input');

      if (btn) {
        btn.addEventListener('click', function() {
          if (_passcodeLocked) {
            showGateError('嘗試次數過多，請 30 秒後再試');
            return;
          }
          var val = input.value.trim();
          if (!val) return;

          sha256(val).then(function(hash) {
            if (hash === PASSCODE_HASH) {
              var user = {
                name: '核心成員',
                email: 'passcode@local',
                picture: '',
                loginAt: Date.now()
              };
              sessionStorage.setItem(STORAGE_KEY, JSON.stringify(user));
              showMain(user);
            } else {
              _passcodeAttempts++;
              if (_passcodeAttempts >= 5) {
                _passcodeLocked = true;
                showGateError('嘗試次數過多，請 30 秒後再試');
                setTimeout(function() {
                  _passcodeLocked = false;
                  _passcodeAttempts = 0;
                }, 30000);
              } else {
                showGateError('通行碼錯誤（' + _passcodeAttempts + '/5）');
              }
            }
          });
        });
      }

      if (input) {
        input.addEventListener('keydown', function(e) {
          if (e.key === 'Enter') {
            btn.click();
          }
        });
      }
    })();

    // ── Init ──
    (function() {
      var existingUser = checkAccess();
      if (existingUser) {
        showMain(existingUser);
      } else {
        initGoogleSignIn();
      }
    })();
  </script>

