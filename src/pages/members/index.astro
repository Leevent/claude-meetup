---
import SEO from '../../components/SEO.astro';
import '../../styles/global.css';
---

<html lang="zh-TW" data-theme="claude-tc">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <SEO
    title="核心圈後台｜Claude 台中小聚"
    description="Claude 台中小聚核心圈成員專屬空間。活動精華、資源包、成員目錄。需要 Google 帳號登入。"
    canonical="https://claudetc.leevent.xyz/members/"
  />
  <meta name="robots" content="noindex, nofollow" />
  <meta http-equiv="Content-Security-Policy" content="script-src 'self' 'unsafe-inline' 'unsafe-eval' https://accounts.google.com https://gsi.google.com; frame-src https://accounts.google.com;" />
  <script src="https://accounts.google.com/gsi/client" async defer></script>
</head>
<body class="min-h-screen bg-base-100 text-base-content">

  <!-- ══════════════════════════════════════════════ -->
  <!-- GATE SCREEN                                    -->
  <!-- ══════════════════════════════════════════════ -->
  <div id="gate" class="gate-screen">
    <div class="gate-card">
      <div class="text-6xl mb-4">🔑</div>
      <h1 class="text-2xl font-bold mb-2">Claude 台中小聚 核心圈後台</h1>
      <p class="text-base-content/70 mb-6">此頁面僅供核心圈成員使用<br />請使用 Google 帳號登入</p>

      <!-- Google Sign-In button -->
      <div id="google-signin-btn" class="flex justify-center mb-4"></div>

      <!-- Password fallback (hidden by default) -->
      <div id="password-fallback" style="display:none;">
        <div class="divider text-sm text-base-content/50">或輸入通行碼</div>
        <div class="flex gap-2 justify-center">
          <input id="passcode-input" type="password" placeholder="通行碼" class="input input-bordered input-sm w-48" />
          <button id="passcode-btn" class="btn btn-sm btn-primary">進入</button>
        </div>
      </div>

      <!-- Error message -->
      <p id="gate-err" class="text-error text-sm mt-4" style="display:none;"></p>

      <!-- Hint -->
      <p class="text-xs text-base-content/30 mt-6">如果登入按鈕沒有出現，請檢查瀏覽器是否封鎖了 Google 的第三方 Cookie</p>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════ -->
  <!-- MAIN CONTENT (hidden until authenticated)      -->
  <!-- ══════════════════════════════════════════════ -->
  <div id="main" style="display:none;">

    <!-- Custom Nav -->
    <nav class="members-nav">
      <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
        <a href="/" class="font-bold text-lg">Claude 台中小聚</a>
        <div class="hidden md:flex items-center gap-4 text-sm">
          <a href="/events/" class="hover:text-primary transition-colors">活動</a>
          <a href="/community/" class="hover:text-primary transition-colors">社群</a>
          <a href="/quiz/" class="hover:text-primary transition-colors">測段位</a>
          <a href="/members/" class="text-primary font-semibold">核心圈</a>
          <a href="/about/" class="hover:text-primary transition-colors">關於</a>
        </div>
        <div class="nav-user" id="nav-user">
          <img id="nav-avatar" src="" alt="avatar" class="nav-avatar" />
          <span id="nav-name" class="text-sm font-medium hidden sm:inline"></span>
          <button onclick="logout()" class="btn btn-ghost btn-xs">登出</button>
        </div>
      </div>
    </nav>

    <!-- Breadcrumb -->
    <div class="max-w-6xl mx-auto px-4 py-3 text-sm breadcrumbs">
      <ul>
        <li><a href="/">首頁</a></li>
        <li>核心圈</li>
      </ul>
    </div>

    <!-- Welcome Banner -->
    <section class="max-w-6xl mx-auto px-4 py-8">
      <div class="welcome-banner">
        <h2 class="text-3xl font-bold mb-2">歡迎回來，<span id="welcome-name">成員</span> 👋</h2>
        <p class="text-base-content/70 mb-6">這裡是核心圈成員專屬空間</p>
        <div class="grid grid-cols-3 gap-4 max-w-md">
          <div class="text-center">
            <div class="text-2xl font-bold text-primary">1</div>
            <div class="text-xs text-base-content/60">累計場次</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-primary">40</div>
            <div class="text-xs text-base-content/60">累計參與</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-primary">&mdash;</div>
            <div class="text-xs text-base-content/60">核心成員</div>
          </div>
        </div>
      </div>
    </section>

    <!-- 📋 活動精華 -->
    <section class="max-w-6xl mx-auto px-4 py-6">
      <h3 class="text-xl font-bold mb-4">📋 活動精華</h3>
      <div class="grid gap-4 md:grid-cols-3">
        <!-- vol.1 — active -->
        <div class="replay-card replay-card--active">
          <div class="replay-badge">vol.1</div>
          <h4 class="font-semibold mb-1">你的 Claude，跟我的一樣嗎？</h4>
          <p class="text-sm text-base-content/70 mb-3">全景式入門。破冰自介、辦公室場景 Demo、生活場景 Demo、進階功能一瞥、分組交流。</p>
          <span class="text-xs text-primary">查看精華 &rarr;</span>
        </div>
        <!-- vol.2 — dimmed -->
        <div class="replay-card replay-card--dimmed">
          <div class="replay-badge replay-badge--soon">vol.2</div>
          <h4 class="font-semibold mb-1 opacity-40">敬請期待</h4>
          <p class="text-sm text-base-content/30">即將推出</p>
        </div>
        <!-- vol.3 — very dimmed -->
        <div class="replay-card replay-card--very-dimmed">
          <div class="replay-badge replay-badge--soon">vol.3</div>
          <h4 class="font-semibold mb-1 opacity-20">敬請期待</h4>
          <p class="text-sm text-base-content/20">即將推出</p>
        </div>
      </div>
    </section>

    <!-- 📦 資源包 -->
    <section class="max-w-6xl mx-auto px-4 py-6">
      <h3 class="text-xl font-bold mb-4">📦 資源包</h3>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="resource-card">
          <div class="text-2xl mb-2">📊</div>
          <h4 class="font-semibold text-sm">簡報</h4>
          <p class="text-xs text-base-content/60">活動簡報 PDF 下載</p>
        </div>
        <div class="resource-card">
          <div class="text-2xl mb-2">🧩</div>
          <h4 class="font-semibold text-sm">Skill 模板包</h4>
          <p class="text-xs text-base-content/60">Claude Code Skill 範本</p>
        </div>
        <div class="resource-card">
          <div class="text-2xl mb-2">💬</div>
          <h4 class="font-semibold text-sm">討論摘要</h4>
          <p class="text-xs text-base-content/60">分組討論精華紀錄</p>
        </div>
        <div class="resource-card">
          <div class="text-2xl mb-2">🗺️</div>
          <h4 class="font-semibold text-sm">學習路徑</h4>
          <p class="text-xs text-base-content/60">Claude 學習建議路線</p>
        </div>
      </div>
    </section>

    <!-- 📂 GitHub 專案學習資料庫 -->
    <section class="max-w-6xl mx-auto px-4 py-6">
      <h3 class="text-xl font-bold mb-4">📂 GitHub 專案學習資料庫</h3>
      <div class="grid gap-4 md:grid-cols-2">
        <a href="https://github.com/anthropics/financial-services-plugins" target="_blank" rel="noopener" class="github-card">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xl">📦</span>
            <span class="font-semibold">anthropics/financial-services-plugins</span>
          </div>
          <p class="text-sm text-base-content/70 mb-2">Anthropic 官方金融服務插件範例。MCP server 實作參考。</p>
          <span class="text-xs text-warning">⭐ 6,900</span>
        </a>
        <a href="https://github.com/cjoke/conway-automaton" target="_blank" rel="noopener" class="github-card">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xl">🤖</span>
            <span class="font-semibold">Conway Automaton</span>
          </div>
          <p class="text-sm text-base-content/70 mb-2">五層記憶架構 AI Agent 系統。本社群系統設計參考來源。</p>
          <span class="text-xs text-warning">⭐ 3,100</span>
        </a>
      </div>
    </section>

    <!-- 👥 成員目錄 -->
    <section class="max-w-6xl mx-auto px-4 py-6">
      <h3 class="text-xl font-bold mb-4">👥 成員目錄</h3>
      <div class="member-card">
        <p class="text-base-content/50 text-center py-8">核心圈正在成形中</p>
      </div>
    </section>

    <!-- 📅 下一場活動 -->
    <section class="max-w-6xl mx-auto px-4 py-6 pb-12">
      <h3 class="text-xl font-bold mb-4">📅 下一場活動</h3>
      <div class="next-event-card">
        <div class="next-event-badge">2026/04/02</div>
        <h4 class="font-semibold text-lg mb-1">Claude 台中小聚 vol.1｜你的 Claude，跟我的一樣嗎？</h4>
        <p class="text-sm text-base-content/70 mb-2">全景式入門。破冰自介、辦公室場景 Demo、生活場景 Demo、進階功能一瞥、分組交流。</p>
        <div class="flex flex-wrap gap-3 text-xs text-base-content/60">
          <span>📍 台中市西區</span>
          <span>🕖 19:00–21:30</span>
          <span>👥 30 人</span>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-base-300 py-6 text-center text-sm text-base-content/50">
      <p>&copy; 2026 Claude 台中小聚 &mdash; 核心圈成員專屬頁面</p>
    </footer>
  </div>

