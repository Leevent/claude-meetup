    /* ── Welcome Banner ── */
    .welcome-banner {
      background: oklch(var(--b2));
      border-radius: 1rem;
      padding: 2rem;
      border: 1px solid oklch(var(--b3));
    }

    /* ── Replay Cards ── */
    .replay-card {
      background: oklch(var(--b2));
      border: 1px solid oklch(var(--b3));
      border-radius: 0.75rem;
      padding: 1.25rem;
      position: relative;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .replay-card--active:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px oklch(var(--p) / 0.15);
      cursor: pointer;
    }
    .replay-card--dimmed {
      opacity: 0.5;
      pointer-events: none;
    }
    .replay-card--very-dimmed {
      opacity: 0.25;
      pointer-events: none;
    }
    .replay-badge {
      display: inline-block;
      background: oklch(var(--p));
      color: oklch(var(--pc));
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0.15rem 0.5rem;
      border-radius: 999px;
      margin-bottom: 0.5rem;
    }
    .replay-badge--soon {
      background: oklch(var(--b3));
      color: oklch(var(--bc) / 0.5);
    }

    /* ── Resource Cards ── */
    .resource-card {
      background: oklch(var(--b2));
      border: 1px solid oklch(var(--b3));
      border-radius: 0.75rem;
      padding: 1.25rem;
      text-align: center;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .resource-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px oklch(var(--p) / 0.1);
    }

    /* ── GitHub Cards ── */
    .github-card {
      display: block;
      background: oklch(var(--b2));
      border: 1px solid oklch(var(--b3));
      border-radius: 0.75rem;
      padding: 1.25rem;
      text-decoration: none;
      color: inherit;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .github-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px oklch(var(--p) / 0.1);
    }

    /* ── Member Card ── */
    .member-card {
      background: oklch(var(--b2));
      border: 1px solid oklch(var(--b3));
      border-radius: 0.75rem;
    }

    /* ── Next Event Card ── */
    .next-event-card {
      background: oklch(var(--b2));
      border: 1px solid oklch(var(--b3));
      border-radius: 0.75rem;
      padding: 1.5rem;
    }
    .next-event-badge {
      display: inline-block;
      background: oklch(var(--p));
      color: oklch(var(--pc));
      font-size: 0.75rem;
      font-weight: 700;
      padding: 0.2rem 0.6rem;
      border-radius: 999px;
      margin-bottom: 0.75rem;
    }
  </style>
</body>
</html>
