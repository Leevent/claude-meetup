  <!-- AUTHENTICATION JAVASCRIPT                      -->
  <!-- ══════════════════════════════════════════════ -->
  <script is:inline>
    // ── Config ──
    var CLIENT_ID = '432869420629-cqd6k47f5oimqdcnp81vshbl6kga1mrj.apps.googleusercontent.com';
    var STORAGE_KEY = 'claude-meetup-user';
    var PASSCODE_HASH = '7d10c954b6224b8209db9313ebf1625f6e393da5f5e04845c4188e1c3645ad86';
    var WHITELIST_ENABLED = true;
    var HASH_SALT = 'claude-tc-meetup-2026';

    var ALLOWED_HASHES = [
