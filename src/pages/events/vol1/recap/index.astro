---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';

const articleLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Claude 台中小聚 vol.1 活動回顧",
  "description": "2026/04/02 首場活動回顧。全景式入門｜角色：認識彼此。",
  "datePublished": "2026-04-02",
  "author": { "@type": "Person", "name": "Lee Vent", "url": "https://leevent.xyz" },
  "publisher": { "@type": "Organization", "name": "Claude 台中小聚", "url": "https://claudetc.leevent.xyz" }
};
---

<BaseLayout
  title="vol.1 活動回顧｜Claude 台中小聚"
  description="Claude 台中小聚 vol.1 活動回顧。2026/04/02 首場活動精彩回顧、參加者心得、現場照片。"
  canonical="https://claudetc.leevent.xyz/events/vol1/recap/"
  ogType="article"
  active="events"
  jsonLd={[articleLd]}
>
  <Breadcrumb items={[
    { name: '首頁', href: '/' },
    { name: '活動中心', href: '/events/' },
    { name: 'vol.1', href: '/events/001-first-meetup/' },
    { name: '活動回顧' }
  ]} />

  <!-- Coming Soon Placeholder -->
